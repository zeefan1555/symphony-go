# Intervox environment variables
# Copy this file to .itervox/.env (preferred) or .env and fill in your values.
# .itervox/.env is gitignored by default; existing shell exports always win.
# All variables are optional — only set what your WORKFLOW.md references.

# ── Linear tracker ──────────────────────────────────────────────────────────
# Required when tracker.type is "linear"
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── GitHub tracker ───────────────────────────────────────────────────────────
# Required when tracker.type is "github"
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── SSH agent hosts ──────────────────────────────────────────────────────────
# Required when agent.ssh_hosts is configured
# SSH_KEY_PATH=/home/user/.ssh/id_ed25519
