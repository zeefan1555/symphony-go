---
// Reusable wrapper for product screenshots.
// - frame="browser": renders traffic-light dots + URL bar (dashboard shots)
// - frame="terminal": renders terminal chrome (TUI / CLI shots)
// - frame="none": just the image, no chrome
interface Props {
  src: string;
  alt: string;
  frame?: 'browser' | 'terminal' | 'none';
  /** Frame size cap — prevents small screenshots from stretching to full container width. */
  size?: 'full' | 'medium' | 'small' | 'phone';
}
const { src, alt, frame = 'browser', size = 'full' } = Astro.props;
const imgSrc = `/screenshots/${src}`;
const wrapperClass = `shot shot--${size}`;
---
<div class={wrapperClass}>
  {frame === 'browser' && (
    <div class="browser">
      <div class="browser-bar">
        <span class="terminal-dot terminal-dot--red"></span>
        <span class="terminal-dot terminal-dot--yellow"></span>
        <span class="terminal-dot terminal-dot--green"></span>
      </div>
      <img src={imgSrc} alt={alt} loading="lazy" decoding="async" class="screenshot-img js-zoomable" />
    </div>
  )}
  {frame === 'terminal' && (
    <div class="terminal">
      <div class="terminal-bar">
        <span class="terminal-dot terminal-dot--red"></span>
        <span class="terminal-dot terminal-dot--yellow"></span>
        <span class="terminal-dot terminal-dot--green"></span>
      </div>
      <img src={imgSrc} alt={alt} loading="lazy" decoding="async" class="screenshot-img js-zoomable" />
    </div>
  )}
  {frame === 'none' && (
    <img src={imgSrc} alt={alt} loading="lazy" decoding="async" class="screenshot-img js-zoomable" />
  )}
</div>

<style>
  .shot {
    width: 100%;
    margin: 0 auto;
  }
  .shot--full { max-width: 100%; }
  .shot--medium { max-width: 880px; }
  .shot--small { max-width: 640px; }
  .shot--phone { max-width: 360px; }
  .screenshot-img {
    display: block;
    width: auto;
    max-width: 100%;
    height: auto;
    margin: 0 auto;
    cursor: zoom-in;
  }
</style>
