        <div class="int-icon" style="color: var(--warning);">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 9h14M9 2v14M3 5l12 8M15 5L3 13"/></svg>
