<script>
  const nav = document.getElementById('nav');
  if (nav) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 20) {
        nav.classList.add('scrolled');
      } else {
        nav.classList.remove('scrolled');
      }
    }, { passive: true });
  }

  // ===== Screenshot lightbox =====
  const lightbox = document.getElementById('lightbox');
  if (lightbox) {
    const lbImg = lightbox.querySelector('img');
    const lbClose = lightbox.querySelector('.lightbox-close');
    const lbInner = lightbox.querySelector('.lightbox-inner');

    function openLightbox(src, alt) {
      if (!lbImg) return;
      lbImg.src = src;
      lbImg.alt = alt || '';
      lightbox.showModal();
    }
    function closeLightbox() {
      lightbox.close();
      if (lbImg) lbImg.src = '';
    }

    document.querySelectorAll('.js-zoomable').forEach((img) => {
      img.addEventListener('click', () => {
        openLightbox(img.src, img.alt);
      });
    });

    lbInner?.addEventListener('click', (e) => {
      if (e.target === lbInner || e.target === lbImg) {
        // clicking the image or the padded backdrop closes
        closeLightbox();
      }
    });
    lbClose?.addEventListener('click', closeLightbox);
    lightbox.addEventListener('click', (e) => {
      // native ::backdrop click — e.target is the dialog itself
      if (e.target === lightbox) closeLightbox();
    });
    lightbox.addEventListener('cancel', (e) => {
      // Esc key default — nothing to prevent, just cleanup
      closeLightbox();
    });
  }
</script>

<dialog id="lightbox" class="lightbox">
  <button type="button" class="lightbox-close" aria-label="Close">&times;</button>
  <div class="lightbox-inner">
    <img src="" alt="" />
  </div>
</dialog>

</body>
</html>
