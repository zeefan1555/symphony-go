---
import '../styles/custom.css';
import Screenshot from '../components/Screenshot.astro';
const title = 'Itervox — Your codebase\'s journey, narrated by agents';
const description = 'Orchestrate AI agents across issues, profiles, and machines. Full visibility from dispatch to PR.';
const githubUrl = 'https://github.com/vnovick/itervox';
---

<html lang="en" data-theme="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://itervox.dev" />
  <meta property="og:image" content="https://itervox.dev/og-image.svg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Itervox — Your codebase's journey, narrated by agents" />
  <meta name="twitter:description" content="Orchestrate AI agents across issues, profiles, and machines. Full visibility from dispatch to PR." />
  <meta name="twitter:image" content="https://itervox.dev/og-image.svg" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    /* ===== Reset ===== */
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: var(--bg);
      color: var(--text);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      overflow-x: hidden;
    }

    .mono { font-family: 'IBM Plex Mono', monospace; }

    /* ===== Container ===== */
    .container {
      max-width: 1120px;
      margin: 0 auto;
      padding: 0 24px;
    }

    /* ===== Section spacing ===== */
    .section {
      padding: 80px 0;
    }
    .section + .section {
      border-top: 1px solid var(--line);
    }

    /* ===== Section headings ===== */
    .section-label {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 1.8px;
      font-weight: 600;
      color: var(--accent-strong);
      margin-bottom: 12px;
    }
    .section-heading {
      font-size: clamp(24px, 3.5vw, 36px);
      font-weight: 700;
      letter-spacing: -0.4px;
      line-height: 1.2;
      margin-bottom: 16px;
    }
    .section-sub {
      font-size: 16px;
      color: var(--text-secondary);
      line-height: 1.6;
      max-width: 560px;
    }
    .section-header {
      margin-bottom: 48px;
    }

    /* ===== 1. Navigation ===== */
    .nav-wrap {
      position: sticky;
      top: 0;
      z-index: 100;
      transition: background 200ms, backdrop-filter 200ms, -webkit-backdrop-filter 200ms, border-color 200ms;
      border-bottom: 1px solid transparent;
    }
    .nav-wrap.scrolled {
      background: rgba(9, 9, 11, 0.75);
      -webkit-backdrop-filter: blur(12px);
      backdrop-filter: blur(12px);
      border-bottom-color: var(--line);
    }
    .nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      max-width: 1120px;
      margin: 0 auto;
      padding: 16px 24px;
    }
    .logo-mark {
      font-family: 'JetBrains Mono', monospace;
      font-weight: 800;
      letter-spacing: 1px;
      display: inline-flex;
      align-items: baseline;
      gap: 0;
    }
    .logo-iter {
      background: var(--gradient-accent);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .logo-slash {
      background: linear-gradient(160deg, #9678e3, #b8a5eb);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .logo-vox { color: #c9cde0; }
    .logo-sub {
      font-family: 'JetBrains Mono', monospace;
      font-size: 8px;
      font-weight: 500;
      color: var(--muted);
      letter-spacing: 3px;
      text-transform: uppercase;
    }
    .nav-logo {
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .nav-logo .logo-mark { font-size: 16px; }
    .nav-logo .logo-sub { font-size: 7px; letter-spacing: 2px; }
    .nav-links {
      display: flex;
      gap: 28px;
      align-items: center;
      list-style: none;
    }
    .nav-links a {
      font-size: 14px;
      font-weight: 500;
      color: var(--text-secondary);
      text-decoration: none;
      transition: color 150ms;
    }
    .nav-links a:hover { color: var(--text); }
    .nav-github {
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }

    /* ===== 2. Hero ===== */
    .hero {
      padding: 100px 0 80px;
      position: relative;
      overflow: hidden;
    }
    .hero-glow {
      position: absolute;
      top: -120px;
      left: 50%;
      transform: translateX(-50%);
      width: 800px;
      height: 400px;
      background: radial-gradient(ellipse, rgba(150,120,227,0.12), rgba(99,102,241,0.04) 50%, transparent 75%);
      pointer-events: none;
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 14px;
      border: 1px solid var(--line-strong);
      border-radius: 999px;
      font-size: 12px;
      font-weight: 500;
      color: var(--text-secondary);
      margin-bottom: 24px;
      background: var(--bg-soft);
    }
    .hero-badge-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--success);
    }
    .hero h1 {
      font-size: clamp(32px, 5vw, 52px);
      font-weight: 700;
      letter-spacing: -1px;
      line-height: 1.1;
      margin-bottom: 20px;
    }
    .hero-sub {
      font-size: 17px;
      color: var(--text-secondary);
      line-height: 1.65;
      margin-bottom: 32px;
      max-width: 460px;
    }
    .hero-ctas {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }
    .install-cmd {
      margin-top: 32px;
      background: var(--bg-elevated);
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      cursor: pointer;
      transition: border-color 150ms;
      max-width: 520px;
      width: 100%;
    }
    .install-cmd:hover { border-color: var(--line-strong); }
    .install-cmd-bar {
      display: flex;
      gap: 6px;
      padding: 8px 14px 0;
    }
    .install-cmd-body {
      padding: 10px 16px 12px;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 13px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .copy-icon {
      margin-left: auto;
      color: var(--muted);
      font-size: 16px;
      transition: color 150ms;
    }
    .install-cmd:hover .copy-icon { color: var(--text-secondary); }
    .icon-check { display: none; }
    .install-cmd.copied .icon-copy { display: none; }
    .install-cmd.copied .icon-check { display: block; color: var(--success); }

    /* ===== Buttons ===== */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 22px;
      border-radius: var(--radius-md);
      font-size: 14px;
      font-weight: 600;
      text-decoration: none;
      transition: opacity 150ms, transform 100ms;
      cursor: pointer;
      border: none;
    }
    .btn:hover { opacity: 0.9; transform: translateY(-1px); }
    .btn-primary {
      background: var(--gradient-accent);
      color: #fff;
    }
    .btn-outline {
      background: transparent;
      border: 1px solid var(--line-strong);
      color: var(--text);
    }
    .btn-outline:hover {
      border-color: var(--accent);
      color: var(--accent-strong);
    }
    .btn-sponsor {
      background: transparent;
      border: 1px solid rgba(219,39,119,0.4);
      color: #db2777;
    }
    .btn-sponsor:hover {
      border-color: #db2777;
      color: #f472b6;
      background: rgba(219,39,119,0.08);
    }

    /* ===== Terminal Chrome ===== */
    .terminal {
      background: #111318;
      border-radius: var(--radius-lg);
      border: 1px solid var(--line-strong);
      overflow: hidden;
      box-shadow: var(--shadow-glow);
    }
    .terminal-bar {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 12px 16px;
      background: rgba(255,255,255,0.03);
      border-bottom: 1px solid var(--line);
    }
    .terminal-dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
    }
    .terminal-dot--red { background: #ff5f57; }
    .terminal-dot--yellow { background: #febc2e; }
    .terminal-dot--green { background: #28c840; }
    .terminal-title {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 12px;
      color: var(--muted);
      margin-left: 8px;
    }
    .terminal-body {
      padding: 20px;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 13px;
      line-height: 1.7;
      overflow-x: auto;
    }
    .terminal-body code {
      display: block;
      white-space: pre;
    }

    /* Terminal color classes */
    .t-prompt { color: var(--muted); }
    .t-cmd { color: var(--text); }
    .t-info { color: var(--teal); }
    .t-accent { color: var(--accent); }
    .t-accent-s { color: var(--accent-strong); }
    .t-success { color: var(--success); }
    .t-muted { color: var(--muted); }
    .t-dim { color: #52525b; }
    .t-warn { color: var(--warning); }
    .t-danger { color: var(--danger); }
    .t-purple { color: var(--purple); }
    .t-text { color: var(--text); }
    .t-teal { color: var(--teal); }
    .t-secondary { color: var(--text-secondary); }

    /* ===== Browser Chrome ===== */
    .browser {
      background: #111318;
      border-radius: var(--radius-lg);
      border: 1px solid var(--line-strong);
      overflow: hidden;
    }
    .browser-bar {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 10px 16px;
      background: #2a2a2e;
      border-bottom: 1px solid var(--line);
    }
    .browser-url {
      flex: 1;
      margin-left: 8px;
      padding: 4px 12px;
      background: rgba(0,0,0,0.3);
      border-radius: var(--radius-sm);
      font-family: 'IBM Plex Mono', monospace;
      font-size: 11px;
      color: var(--muted);
    }
    .browser-body {
      padding: 20px;
      min-height: 200px;
    }

    /* ===== 3. Problem/Solution ===== */
    .compare-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }
    .compare-card {
      background: var(--bg-soft);
      border: 1px solid var(--line);
      border-radius: var(--radius-lg);
      padding: 32px;
    }
    .compare-card--highlight {
      border-color: var(--accent);
      box-shadow: 0 0 30px -10px rgba(99,102,241,0.25);
    }
    .compare-title {
      font-size: 18px;
      font-weight: 600;
      margin-bottom: 24px;
    }
    .compare-steps {
      list-style: none;
    }
    .compare-steps li {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 8px 0;
      font-size: 14px;
      color: var(--text-secondary);
      border-bottom: 1px solid var(--line);
    }
    .compare-steps li:last-child { border-bottom: none; }
    .compare-step-num {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 12px;
      color: var(--muted);
      margin-right: 10px;
    }
    .compare-step-time {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 12px;
      color: var(--muted);
    }
    .compare-step-auto {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 11px;
      color: var(--teal);
      padding: 2px 8px;
      background: rgba(20,184,166,0.1);
      border-radius: var(--radius-sm);
    }
    .compare-step-human {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 11px;
      color: var(--accent-strong);
      padding: 2px 8px;
      background: rgba(99,102,241,0.1);
      border-radius: var(--radius-sm);
    }
    .compare-total {
      margin-top: 20px;
      padding-top: 16px;
      border-top: 1px solid var(--line-strong);
      font-size: 14px;
      font-weight: 600;
      color: var(--text);
    }

    /* ===== Split layouts (How It Works) ===== */
    .split {
      display: grid;
      grid-template-columns: 5fr 7fr;
      gap: 48px;
      align-items: center;
    }
    .split > * { min-width: 0; }
    .split-text h3 {
      font-size: 24px;
      font-weight: 700;
      letter-spacing: -0.3px;
      margin-bottom: 12px;
    }
    .split-text p {
      font-size: 15px;
      color: var(--text-secondary);
      line-height: 1.65;
      margin-bottom: 20px;
    }
    .split-text ul {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .split-text li {
      font-size: 14px;
      color: var(--text-secondary);
      display: flex;
      align-items: flex-start;
      gap: 10px;
    }
    .split-text li::before {
      content: '';
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--accent);
      margin-top: 7px;
      flex-shrink: 0;
    }

    /* ===== 6. Dashboard Mockups ===== */
    .dashboard-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }
    .dashboard-panel { width: 100%; }
    .dashboard-label {
      margin-top: 12px;
      font-size: 13px;
      color: var(--text-secondary);
      font-weight: 500;
    }

    .timeline-tok {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 9px;
      color: var(--muted);
      padding: 2px 6px;
      background: var(--bg-elevated);
      border-radius: 3px;
      margin-left: 6px;
      white-space: nowrap;
    }

    .log-line {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 11px;
      line-height: 1.8;
      padding: 0 4px;
    }

    .profile-dot {
      width: 8px; height: 8px; border-radius: 50%;
    }

    .keybinds {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 24px;
      justify-content: center;
    }
    .keybind {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 5px 12px;
      background: var(--bg-soft);
      border: 1px solid var(--line);
      border-radius: var(--radius-sm);
      font-family: 'IBM Plex Mono', monospace;
      font-size: 12px;
      color: var(--text-secondary);
    }
    .keybind kbd {
      display: inline-block;
      padding: 1px 6px;
      background: var(--bg-elevated);
      border: 1px solid var(--line-strong);
      border-radius: 3px;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 11px;
      color: var(--accent-strong);
    }

    /* ===== 8. Agent Cards ===== */
    .agent-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
    .agent-card {
      background: var(--bg-soft);
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      padding: 24px;
      display: flex;
      align-items: center;
      gap: 16px;
      border-left: 3px solid;
    }
    .agent-card--active { opacity: 1; }
    .agent-card--soon { opacity: 0.55; }
    .agent-logo {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 18px;
      color: #fff;
      flex-shrink: 0;
    }
    .agent-info { flex: 1; }
    .agent-name {
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 2px;
    }
    .agent-company {
      font-size: 12px;
      color: var(--muted);
    }
    .agent-badge {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 11px;
      padding: 3px 10px;
      border-radius: 999px;
    }
    .agent-badge--active {
      background: rgba(34,197,94,0.12);
      color: var(--success);
    }
    .agent-badge--soon {
      color: var(--warning);
      border: 1px dashed var(--warning);
      background: transparent;
    }
    .agent-note {
      text-align: center;
      margin-top: 24px;
      font-size: 14px;
    }

    /* ===== 8b. Use Case: Reassignment ===== */
    .usecase {
      margin-top: 64px;
      background: var(--bg-soft);
      border: 1px solid var(--line);
      border-radius: var(--radius-lg);
      padding: 40px 36px;
    }
    .usecase-label {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: var(--warning);
      font-weight: 600;
      margin-bottom: 12px;
    }
    .usecase-heading {
      font-size: 22px;
      font-weight: 700;
      margin-bottom: 8px;
    }
    .usecase-desc {
      font-size: 15px;
      color: var(--text-secondary);
      line-height: 1.7;
      max-width: 600px;
      margin-bottom: 32px;
    }
    .usecase-flow {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
      justify-content: center;
    }
    .flow-step {
      background: var(--bg-elevated);
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      padding: 16px 20px;
      text-align: center;
      min-width: 140px;
    }
    .flow-step-num {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 10px;
      color: var(--muted);
      margin-bottom: 6px;
    }
    .flow-step-title {
      font-size: 13px;
      font-weight: 600;
      margin-bottom: 4px;
    }
    .flow-step-detail {
      font-size: 11px;
      color: var(--muted);
      line-height: 1.4;
    }
    .flow-step--problem {
      border-color: var(--danger);
      border-style: dashed;
    }
    .flow-step--solution {
      border-color: var(--success);
    }
    .flow-arrow {
      font-size: 20px;
      color: var(--muted);
    }
    .usecase-profiles {
      margin-top: 32px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
    @media (max-width: 600px) {
      .usecase-profiles { grid-template-columns: 1fr; }
    }
    .profile-card {
      background: var(--bg);
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      padding: 16px 20px;
    }
    .profile-header {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 10px;
    }
    .profile-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .profile-name {
      font-size: 14px;
      font-weight: 600;
    }
    .profile-runner {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 11px;
      color: var(--muted);
      margin-left: auto;
    }
    .profile-yaml {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 11px;
      color: var(--text-secondary);
      background: var(--bg-soft);
      border-radius: var(--radius-sm);
      padding: 10px 12px;
      line-height: 1.6;
      font-style: italic;
      color: var(--muted);
      max-width: 600px;
      margin-left: auto;
      margin-right: auto;
    }

    /* ===== 9. Observability Cards ===== */
    .obs-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
    }
    .obs-card {
      background: var(--bg-soft);
      border: 1px solid var(--line);
      border-radius: var(--radius-lg);
      overflow: hidden;
    }
    .obs-mockup {
      padding: 16px;
      min-height: 120px;
      border-bottom: 1px solid var(--line);
    }
    .obs-text {
      padding: 20px;
    }
    .obs-text h4 {
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 6px;
    }
    .obs-text p {
      font-size: 13px;
      color: var(--text-secondary);
      line-height: 1.6;
    }

    /* ===== 10. Integration Cards ===== */
    .int-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 16px;
    }
    .int-card {
      background: var(--bg-soft);
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      padding: 24px;
      transition: border-color 200ms;
    }
    .int-card:hover {
      border-color: var(--line-strong);
    }
    .int-icon {
      width: 36px;
      height: 36px;
      border-radius: var(--radius-sm);
      background: var(--bg-elevated);
      border: 1px solid var(--line);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 14px;
      font-size: 16px;
    }
    .int-card h4 {
      font-size: 15px;
      font-weight: 600;
      margin-bottom: 6px;
    }
    .int-card p {
      font-size: 13px;
      color: var(--text-secondary);
      line-height: 1.5;
    }

    /* ===== Feature row — section-header style title + description left, features right, screenshot below ===== */
    .feature-row {
      display: flex;
      flex-direction: column;
      gap: 36px;
      margin-bottom: 96px;
    }
    .feature-row:last-child { margin-bottom: 0; }
    .feature-row > .split-text {
      order: 1;
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 56px;
      max-width: 960px;
      margin: 0 auto;
      text-align: left;
      align-items: start;
    }
    .feature-row > .split-text > h3 {
      grid-column: 1;
      grid-row: 1;
      font-size: clamp(22px, 2.6vw, 30px);
      font-weight: 700;
      letter-spacing: -0.3px;
      line-height: 1.25;
      margin-bottom: 14px;
    }
    .feature-row > .split-text > p {
      grid-column: 1;
      grid-row: 2;
      font-size: 16px;
      color: var(--text-secondary);
      line-height: 1.6;
    }
    .feature-row > .split-text > ul {
      grid-column: 2;
      grid-row: 1 / span 2;
      margin: 0;
      padding-left: 18px;
      color: var(--text-secondary);
      line-height: 1.8;
    }
    .feature-row > :not(.split-text) {
      order: 2;
      width: 100%;
      display: flex;
      justify-content: center;
    }

    /* Side-by-side variant: explanation left, image right (or vice versa) */
    .feature-row--side {
      flex-direction: row;
      align-items: center;
      gap: 56px;
    }
    .feature-row--side > .split-text {
      order: 0;
      flex: 1 1 0;
      max-width: none;
      margin: 0;
      display: block; /* stack internally when side layout — no room for 2-col */
    }
    .feature-row--side > .split-text > h3,
    .feature-row--side > .split-text > p,
    .feature-row--side > .split-text > ul {
      grid-column: auto;
      grid-row: auto;
    }
    .feature-row--side > .split-text > ul {
      display: block;
      padding-left: 18px;
      margin-top: 16px;
    }
    .feature-row--side > :not(.split-text) {
      order: 1;
      flex: 0 0 auto;
      width: auto;
    }

    /* ===== CSS phone frame (for mobile dashboard capture) ===== */
    .phone-frame {
      width: 288px;
      height: 560px;
      border-radius: 40px;
      padding: 10px;
      background: #0a0a0a;
      box-shadow:
        0 30px 60px rgba(0,0,0,0.55),
        0 0 0 2px #1f1f23,
        inset 0 0 0 1px #2a2a30;
      position: relative;
    }
    .phone-frame::before {
      content: '';
      position: absolute;
      top: 12px;
      left: 50%;
      transform: translateX(-50%);
      width: 110px;
      height: 22px;
      background: #0a0a0a;
      border-radius: 0 0 14px 14px;
      z-index: 2;
    }
    .phone-screen {
      width: 100%;
      height: 100%;
      max-height: 500px;
      overflow-y: auto;
      overflow-x: hidden;
      background: #000;
      border-radius: 30px;
      scrollbar-width: thin;
      scrollbar-color: #2a2a30 transparent;
    }
    .phone-screen::-webkit-scrollbar { width: 4px; }
    .phone-screen::-webkit-scrollbar-thumb { background: #2a2a30; border-radius: 2px; }
    .phone-screen img {
      display: block;
      width: 100%;
      height: auto;
      cursor: zoom-in;
    }

    /* ===== Lightbox dialog ===== */
    .lightbox {
      padding: 0;
      border: none;
      background: transparent;
      max-width: 100vw;
      max-height: 100vh;
      width: 100vw;
      height: 100vh;
      overflow: hidden;
    }
    .lightbox::backdrop {
      background: rgba(0, 0, 0, 0.92);
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
    }
    .lightbox-inner {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: zoom-out;
      padding: 32px;
    }
    .lightbox-inner img {
      max-width: 100%;
      max-height: 100%;
      object-fit: contain;
      box-shadow: 0 30px 80px rgba(0,0,0,0.6);
      border-radius: 8px;
    }
    .lightbox-close {
      position: fixed;
      top: 20px;
      right: 20px;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      border: 1px solid rgba(255,255,255,0.2);
      background: rgba(0,0,0,0.5);
      color: #fff;
      font-size: 20px;
      line-height: 1;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .lightbox-close:hover {
      background: rgba(0,0,0,0.8);
    }

    /* ===== Configure-without-restarts grid ===== */
    .config-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 24px;
    }
    .config-card {
      background: var(--bg-soft);
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      padding: 20px;
      overflow: hidden;
      transition: border-color 200ms;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .config-card:hover {
      border-color: var(--line-strong);
    }
    .config-card .shot {
      max-width: 100%;
    }
    .config-card .screenshot-img {
      max-height: 220px;
      width: auto;
      object-fit: contain;
      object-position: top center;
    }
    .config-card h4 {
      font-size: 14px;
      font-weight: 600;
      margin: 0;
    }
    .config-card p {
      font-size: 13px;
      color: var(--text-secondary);
      line-height: 1.5;
      margin: 0;
    }

    /* ===== Workflow Graph Mockup ===== */
    .workflow-graph {
      display: flex;
      align-items: center;
      gap: 0;
      padding: 32px 16px;
      overflow-x: auto;
      justify-content: center;
      flex-wrap: wrap;
    }
    .wf-node {
      background: var(--bg-elevated);
      border: 2px solid var(--line-strong);
      border-radius: var(--radius-md);
      padding: 14px 20px;
      text-align: center;
      min-width: 130px;
      position: relative;
    }
    .wf-node-label {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 11px;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 2px;
    }
    .wf-node-role {
      font-size: 10px;
      color: var(--muted);
    }
    .wf-arrow {
      font-size: 18px;
      color: var(--muted);
      padding: 0 6px;
      flex-shrink: 0;
    }
    .wf-branch {
      display: flex;
      flex-direction: column;
      gap: 8px;
      align-items: flex-start;
    }
    .wf-branch-row {
      display: flex;
      align-items: center;
      gap: 0;
    }
    .wf-branch-label {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 10px;
      font-weight: 600;
      padding: 0 8px;
      flex-shrink: 0;
    }

    /* Blocker badges for dependency mockup */
    .blocker-row {
      display: flex;
      align-items: center;
      gap: 6px;
      margin-top: 6px;
      font-size: 9px;
      color: var(--danger);
    }
    .blocker-badge {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 9px;
      padding: 1px 6px;
      border-radius: 3px;
      background: rgba(239,68,68,0.12);
      color: var(--danger);
      cursor: pointer;
    }

    /* Hook list styling */
    .hook-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .hook-list li {
      font-size: 14px;
      color: var(--text-secondary);
      line-height: 1.5;
    }
    .hook-list code {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 12px;
      color: var(--accent-strong);
      background: var(--bg-elevated);
      padding: 1px 6px;
      border-radius: 3px;
    }

    /* ===== 11. CTA Section ===== */
    .cta-section {
      text-align: center;
    }
    .cta-install {
      max-width: 540px;
      margin: 0 auto 16px;
    }
    .cta-alt {
      font-size: 13px;
      color: var(--muted);
      margin-bottom: 8px;
    }
    .cta-buttons {
      display: flex;
      gap: 12px;
      justify-content: center;
      margin-top: 32px;
      flex-wrap: wrap;
    }

    /* ===== 12. Footer ===== */
    .footer {
      border-top: 1px solid var(--line);
      padding: 64px 0 32px;
    }
    .footer-grid {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 48px;
      margin-bottom: 48px;
    }
    .footer-brand {
      font-size: 18px;
      font-weight: 700;
      margin-bottom: 12px;
    }
    .footer-etym {
      font-size: 13px;
      color: var(--muted);
      font-style: italic;
      line-height: 1.6;
      max-width: 280px;
    }
    .footer-col h5 {
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1.4px;
      color: var(--text-secondary);
      margin-bottom: 14px;
    }
    .footer-col ul {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .footer-col a {
      font-size: 14px;
      color: var(--muted);
      text-decoration: none;
      transition: color 150ms;
    }
    .footer-col a:hover { color: var(--text); }
    .footer-bottom {
      border-top: 1px solid var(--line);
      padding-top: 24px;
      font-size: 13px;
      color: var(--muted);
      text-align: center;
    }

    /* ===== Responsive ===== */
    @media (max-width: 900px) {
      .hero-grid, .split, .compare-grid, .dashboard-grid, .agent-grid {
        grid-template-columns: 1fr;
      }
      .obs-grid, .int-grid, .config-grid {
        grid-template-columns: 1fr 1fr;
      }
      .footer-grid {
        grid-template-columns: 1fr 1fr;
      }
      .feature-row > .split-text {
        grid-template-columns: 1fr;
        gap: 20px;
      }
      .feature-row > .split-text > h3,
      .feature-row > .split-text > p,
      .feature-row > .split-text > ul {
        grid-column: 1;
        grid-row: auto;
      }
      .feature-row--side {
        flex-direction: column;
        gap: 32px;
      }
    }
    @media (max-width: 600px) {
      .obs-grid, .int-grid, .config-grid, .footer-grid {
        grid-template-columns: 1fr;
      }
      .nav-links { gap: 16px; }
      .hero { padding: 60px 0 40px; }
      .section { padding: 48px 0; }
      .keybinds { gap: 4px; }
      .keybind { padding: 4px 8px; font-size: 10px; }
    }
  </style>
</head>
